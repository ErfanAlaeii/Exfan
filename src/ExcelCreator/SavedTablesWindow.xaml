<Window x:Class="ExcelCreator.SavedTablesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Height="520"
        Width="560"
        MinHeight="400"
        MinWidth="480"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterOwner"
        FlowDirection="LeftToRight"
        Language="fa-IR"
        Icon="{x:Null}">
    <Grid Margin="28" FlowDirection="RightToLeft">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="HeaderText"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       TextAlignment="Right"/>
            <TextBlock x:Name="ListHintText"
                       FontSize="13"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,0"
                       TextAlignment="Right"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Padding="8">
            <Grid>
                <ListBox x:Name="TablesList"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="14"
                         FlowDirection="RightToLeft"
                         MouseDoubleClick="TablesList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="8,10">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           TextAlignment="Right"/>
                                <TextBlock Text="{Binding Subtitle}"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,4,0,0"
                                           TextAlignment="Right"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="EmptyText"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0" FlowDirection="RightToLeft">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    x:Name="BackButton"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right"
                    Click="Back_Click"/>
            <Button Grid.Column="1"
                    x:Name="DeleteButton"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="Delete_Click"/>
            <Button Grid.Column="2"
                    x:Name="OpenButton"
                    Style="{StaticResource PrimaryButton}"
                    Click="Open_Click"/>
        </Grid>
    </Grid>
</Window>
