<Window x:Class="ExcelCreator.CalculationResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Height="360"
        Width="460"
        MinHeight="240"
        MinWidth="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FlowDirection="LeftToRight"
        Language="fa-IR"
        Background="{StaticResource SurfaceBrush}"
        Icon="{x:Null}">
    <Border Margin="20"
            Background="White"
            CornerRadius="12"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            Padding="24"
            FlowDirection="RightToLeft">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       TextAlignment="Right"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="ErrorText"
                       Grid.Row="1"
                       Foreground="#B91C1C"
                       FontSize="14"
                       TextWrapping="Wrap"
                       TextAlignment="Right"
                       Visibility="Collapsed"/>

            <ScrollViewer x:Name="ResultsScrollViewer"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="280"
                          FlowDirection="RightToLeft">
                <ItemsControl x:Name="ResultItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Label}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           TextAlignment="Right"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FormattedValue}"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="16,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="SummaryText"
                       Grid.Row="2"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}"
                       TextAlignment="Right"
                       Margin="0,8,0,0"
                       Visibility="Collapsed"/>

            <Button Grid.Row="3"
                    x:Name="CloseButton"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Left"
                    MinWidth="100"
                    Margin="0,20,0,0"
                    IsDefault="True"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
