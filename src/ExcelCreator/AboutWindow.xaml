<Window x:Class="ExcelCreator.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Height="360"
        Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Language="fa-IR"
        Background="{StaticResource SurfaceBrush}">
    <Border Margin="24" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
        <StackPanel>
            <TextBlock x:Name="ProductNameText"
                       FontSize="22"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock x:Name="VersionText"
                       FontSize="14"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,8,0,16"
                       TextAlignment="Center"/>
            <TextBlock TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="13"
                       Foreground="{StaticResource TextBrush}"
                       LineHeight="22">
                برنامه دسکتاپ ساخت دست عرفان برای ساخت فایل‌های اکسل به زبان فارسی.<LineBreak/>
                پشتیبانی از تقویم میلادی و شمسی.<LineBreak/>
            </TextBlock>
            <TextBlock x:Name="CopyrightText"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,16,0,20"
                       TextAlignment="Center"/>
            <Button x:Name="CloseButton"
                    Content=""
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Center"
                    MinWidth="120"
                    Click="Close_Click"/>
        </StackPanel>
    </Border>
</Window>
