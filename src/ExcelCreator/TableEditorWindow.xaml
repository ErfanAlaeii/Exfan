<Window x:Class="ExcelCreator.TableEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ExcelCreator.Controls"
        Title=""
        Height="580"
        Width="720"
        MinHeight="480"
        MinWidth="600"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterOwner"
        FlowDirection="LeftToRight"
        Language="fa-IR"
        Icon="{x:Null}">
    <Grid Margin="28" FlowDirection="RightToLeft">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TableNameText"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       TextAlignment="Right"/>
            <TextBlock x:Name="CalendarHintText"
                       FontSize="13"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,0"
                       TextAlignment="Right"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Padding="20"
                FlowDirection="RightToLeft">
            <StackPanel>
                <controls:CalculationActionsControl x:Name="CalculationActions"
                                                    Margin="0,0,0,16"/>
                <controls:TableRowsEditor x:Name="RowsEditor"
                                          RowsChanged="RowsEditor_RowsChanged"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0" FlowDirection="RightToLeft">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    x:Name="BackButton"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right"
                    Click="Back_Click"/>
            <Button Grid.Column="1"
                    x:Name="ExportButton"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="Export_Click"/>
            <Button Grid.Column="2"
                    x:Name="SaveButton"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
