<Window x:Class="ExcelCreator.CreateTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ExcelCreator.Controls"
        Height="580"
        Width="720"
        MinHeight="480"
        MinWidth="600"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterOwner"
        FlowDirection="LeftToRight"
        Language="fa-IR"
        Icon="{x:Null}">
    <Grid Margin="28" FlowDirection="RightToLeft">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock x:Name="StepTitle"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       TextAlignment="Right"/>
            <TextBlock x:Name="StepSubtitle"
                       FontSize="14"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Right"/>
            <TextBlock x:Name="StepIndicator"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,10,0,0"
                       TextAlignment="Right"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,20,0,20"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Padding="24"
                FlowDirection="RightToLeft">
            <Grid>
                <StackPanel x:Name="StepName" Visibility="Visible">
                    <TextBlock x:Name="TableNameLabel"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               TextAlignment="Right"/>
                    <TextBox x:Name="TableNameBox"
                             Padding="10,8"
                             FontSize="14"
                             FlowDirection="RightToLeft"
                             TextAlignment="Right"
                             TextChanged="TableNameBox_TextChanged"/>
                    <TextBlock x:Name="TableNameHint"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               TextAlignment="Right"/>
                </StackPanel>

                <controls:CalendarSelectorControl x:Name="CalendarSelector"
                                                  Visibility="Collapsed"
                                                  CalendarChanged="CalendarSelector_CalendarChanged"/>

                <StackPanel x:Name="StepDataEntry" Visibility="Collapsed">
                    <controls:CalculationActionsControl x:Name="CalculationActions"
                                                        Margin="0,0,0,16"/>
                    <controls:TableRowsEditor x:Name="RowsEditor"
                                              RowsChanged="RowsEditor_RowsChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" FlowDirection="RightToLeft">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    x:Name="CancelButton"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right"
                    Click="Cancel_Click"/>
            <Button x:Name="BackButton"
                    Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Visibility="Collapsed"
                    Click="Back_Click"/>
            <Button x:Name="ExportButton"
                    Grid.Column="2"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Visibility="Collapsed"
                    Click="Export_Click"/>
            <Button x:Name="NextButton"
                    Grid.Column="3"
                    Style="{StaticResource PrimaryButton}"
                    Click="Next_Click"/>
        </Grid>
    </Grid>
</Window>
