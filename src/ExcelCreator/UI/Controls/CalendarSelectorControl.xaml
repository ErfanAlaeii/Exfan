<UserControl x:Class="ExcelCreator.UI.Controls.CalendarSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft">
    <StackPanel>
        <TextBlock x:Name="TitleText"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Margin="0,0,0,8"
                   TextAlignment="Right"/>
        <StackPanel Orientation="Horizontal"
                    FlowDirection="RightToLeft"
                    Margin="0,0,0,6">
            <RadioButton x:Name="JalaliRadio"
                         FontSize="14"
                         Margin="0,0,24,0"
                         GroupName="CalendarSelector"
                         Checked="CalendarRadio_Changed"/>
            <RadioButton x:Name="GregorianRadio"
                         FontSize="14"
                         GroupName="CalendarSelector"
                         Checked="CalendarRadio_Changed"/>
        </StackPanel>
        <TextBlock x:Name="HintText"
                   FontSize="12"
                   Foreground="{StaticResource MutedBrush}"
                   TextAlignment="Right"
                   TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
