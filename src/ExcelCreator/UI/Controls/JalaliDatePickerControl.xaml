<UserControl x:Class="ExcelCreator.UI.Controls.JalaliDatePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Language="fa-IR">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="DisplayBox"
                 Grid.Column="0"
                 IsReadOnly="True"
                 FontSize="14"
                 Padding="10,8"
                 TextAlignment="Right"
                 FlowDirection="RightToLeft"/>

        <ToggleButton x:Name="DropDownButton"
                      Grid.Column="1"
                      Width="36"
                      Padding="0"
                      Margin="4,0,0,0"
                      Click="DropDownButton_Click">
            <Path Data="M0,0 L4,4 L8,0 Z"
                  Fill="#64748B"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Stretch="Uniform"
                  Width="10"
                  Height="6"/>
        </ToggleButton>

        <Popup x:Name="CalendarPopup"
               PlacementTarget="{Binding ElementName=DisplayBox}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    MinWidth="280">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="NextMonthButton"
                                Grid.Column="0"
                                Content="›"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Click="NextMonthButton_Click"/>
                        <TextBlock x:Name="MonthYearText"
                                   Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <Button x:Name="PreviousMonthButton"
                                Grid.Column="2"
                                Content="‹"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Click="PreviousMonthButton_Click"/>
                    </Grid>

                    <UniformGrid x:Name="WeekdayHeaderGrid"
                                 Rows="1"
                                 Columns="7"
                                 Margin="0,0,0,4"/>

                    <UniformGrid x:Name="DayGrid"
                                 Rows="6"
                                 Columns="7"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
