<Window x:Class="ExcelCreator.UI.Dialogs.FieldSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Height="360"
        Width="440"
        MinHeight="320"
        MinWidth="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FlowDirection="LeftToRight"
        Language="fa-IR"
        Background="{StaticResource SurfaceBrush}"
        Icon="{x:Null}">
    <Border Margin="20"
            Background="White"
            CornerRadius="12"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            Padding="24"
            FlowDirection="RightToLeft">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="PromptText"
                       Grid.Row="0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       TextAlignment="Right"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                <TextBlock x:Name="ActionLabel"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"
                           TextAlignment="Right"/>
                <ComboBox x:Name="ActionBox"
                          Padding="10,8"
                          FontSize="14"
                          FlowDirection="RightToLeft"
                          SelectionChanged="ActionBox_SelectionChanged"/>
            </StackPanel>

            <StackPanel x:Name="DetailsPanel" Grid.Row="2" Margin="0,0,0,12">
                <TextBlock x:Name="FieldSelectLabel"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"
                           TextAlignment="Right"
                           Visibility="Collapsed"/>
                <ComboBox x:Name="FieldBox"
                          Padding="10,8"
                          FontSize="14"
                          FlowDirection="RightToLeft"
                          Visibility="Collapsed"
                          Margin="0,0,0,10"
                          SelectionChanged="FieldBox_SelectionChanged"/>
                <TextBlock x:Name="NameInputLabel"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"
                           TextAlignment="Right"
                           Visibility="Collapsed"/>
                <TextBox x:Name="NameBox"
                         Padding="10,8"
                         FontSize="14"
                         FlowDirection="RightToLeft"
                         TextAlignment="Right"
                         Visibility="Collapsed"/>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        FlowDirection="RightToLeft"
                        Margin="0,8,0,0">
                <Button x:Name="ConfirmButton"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="100"
                        Margin="0,0,12,0"
                        IsDefault="True"
                        Click="Confirm_Click"/>
                <Button x:Name="CancelButton"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="100"
                        IsCancel="True"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
