<Window x:Class="ExcelCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="680"
        Width="960"
        MinHeight="560"
        MinWidth="720"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight"
        Language="fa-IR"
        Icon="{x:Null}">
    <Window.Resources>
        <Style x:Key="HomeCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                    <Setter Property="Background" Value="#FAFBFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="32,28,32,24" FlowDirection="RightToLeft">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hero header -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBrush}"
                CornerRadius="16"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Padding="24,22"
                Margin="0,0,0,24">
            <StackPanel>
                <TextBlock x:Name="WelcomeText"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           TextAlignment="Right"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="14"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           TextAlignment="Right"/>
            </StackPanel>
        </Border>

        <!-- Tools section -->
        <TextBlock x:Name="ToolsSectionTitle"
                   Grid.Row="1"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,10"
                   TextAlignment="Right"/>

        <Border Grid.Row="2"
                Style="{StaticResource HomeCardBorder}"
                Margin="0,0,0,28"
                MouseLeftButtonUp="ManagePersonnel_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="48"
                        Height="48"
                        CornerRadius="12"
                        Background="#EFF6FF"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="👥"
                               FontSize="24"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="PersonnelCardTitle"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               TextAlignment="Right"/>
                    <TextBlock x:Name="PersonnelCardHint"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Right"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="‹"
                           FontSize="22"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <!-- Templates section header + search -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TemplatesSectionTitle"
                       Grid.Column="0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center"
                       TextAlignment="Right"/>

            <Border Grid.Column="1"
                    Width="320"
                    Margin="16,0,0,0"
                    Background="White"
                    CornerRadius="8"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">
                <TextBox x:Name="SearchBox"
                         Padding="12,10"
                         FontSize="14"
                         BorderThickness="0"
                         Background="Transparent"
                         FlowDirection="RightToLeft"
                         HorizontalContentAlignment="Right"
                         TextAlignment="Right"
                         Language="fa-IR"
                         PreviewMouseDown="SearchBox_PreviewMouseDown"
                         GotFocus="SearchBox_GotFocus"
                         LostFocus="SearchBox_LostFocus"
                         TextChanged="SearchBox_TextChanged"/>
            </Border>
        </Grid>

        <!-- Template cards -->
        <Grid Grid.Row="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="TemplateList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="300"
                                    Margin="8"
                                    Style="{StaticResource HomeCardBorder}"
                                    MouseLeftButtonUp="TemplateCard_Click">
                                <StackPanel>
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="32"
                                               Margin="0,0,0,10"
                                               TextAlignment="Right"/>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               TextAlignment="Right"/>
                                    <TextBlock Text="{Binding Category}"
                                               FontSize="12"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,4,0,8"
                                               TextAlignment="Right"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="13"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Right"
                                               LineHeight="20"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="EmptyMessage"
                       Foreground="{StaticResource MutedBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>

        <TextBlock x:Name="VersionFooterText"
                   Grid.Row="5"
                   FontSize="12"
                   Foreground="{StaticResource MutedBrush}"
                   Margin="0,16,0,0"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
