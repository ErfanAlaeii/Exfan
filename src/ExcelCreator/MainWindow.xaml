<Window x:Class="ExcelCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="640"
        Width="960"
        MinHeight="540"
        MinWidth="720"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen"
        FlowDirection="LeftToRight"
        Language="fa-IR"
        Icon="{x:Null}">
    <Grid Margin="32" FlowDirection="RightToLeft">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="WelcomeText"
                   Grid.Row="0"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"
                   HorizontalAlignment="Left"
                   TextAlignment="Right"
                   FlowDirection="RightToLeft"
                   Margin="0,0,0,16"/>

        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Margin="0,0,0,16"
                 Padding="12,10"
                 FontSize="14"
                 FlowDirection="LeftToRight"
                 HorizontalContentAlignment="Left"
                 TextAlignment="Left"
                 Language="fa-IR"
                 PreviewMouseDown="SearchBox_PreviewMouseDown"
                 GotFocus="SearchBox_GotFocus"
                 TextChanged="SearchBox_TextChanged">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="FlowDirection" Value="LeftToRight"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="TextAlignment" Value="Left"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TextBox">
                                <Border Background="White"
                                        CornerRadius="8"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Margin="12,8"
                                                  FlowDirection="LeftToRight"
                                                  HorizontalAlignment="Left"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Hidden"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TextBox.Style>
        </TextBox>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" FlowDirection="RightToLeft">
            <ItemsControl x:Name="TemplateList" FlowDirection="RightToLeft">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel FlowDirection="RightToLeft"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280"
                                Margin="0,0,16,16"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Padding="20"
                                Cursor="Hand"
                                FlowDirection="RightToLeft"
                                MouseLeftButtonUp="TemplateCard_Click">
                            <StackPanel>
                                <TextBlock Text="{Binding Icon}" FontSize="32" Margin="0,0,0,8" TextAlignment="Right"/>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           TextAlignment="Right"/>
                                <TextBlock Text="{Binding Category}"
                                           FontSize="12"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Margin="0,4,0,8"
                                           TextAlignment="Right"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="13"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Right"
                                           MaxHeight="60"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="EmptyMessage"
                   Grid.Row="2"
                   Foreground="{StaticResource MutedBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Visibility="Collapsed"/>

        <TextBlock x:Name="VersionFooterText"
                   Grid.Row="3"
                   FontSize="12"
                   Foreground="{StaticResource MutedBrush}"
                   Margin="0,16,0,0"
                   TextAlignment="Right"
                   HorizontalAlignment="Right"/>
    </Grid>
</Window>
