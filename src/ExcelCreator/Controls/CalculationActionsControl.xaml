<UserControl x:Class="ExcelCreator.Controls.CalculationActionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             Language="fa-IR">
    <StackPanel>
        <TextBlock x:Name="SectionTitleText"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   TextAlignment="Right"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="SectionHintText"
                   FontSize="12"
                   Foreground="{StaticResource MutedBrush}"
                   TextAlignment="Right"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>
        <ItemsControl x:Name="ActionsItems">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel FlowDirection="RightToLeft"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Label}"
                            ToolTip="{Binding Description}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,8"
                            Margin="0,0,8,8"
                            Tag="{Binding Id}"
                            Click="ActionButton_Click"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock x:Name="NoActionsText"
                   FontSize="12"
                   Foreground="{StaticResource MutedBrush}"
                   TextAlignment="Right"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>
    </StackPanel>
</UserControl>
